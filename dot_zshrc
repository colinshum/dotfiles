# Thin entrypoint: keep real zsh config in ~/.config/zsh.
# Default XDG config dir when caller did not predefine it.
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
# Default XDG cache dir when caller did not predefine it.
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
# Default XDG state dir when caller did not predefine it.
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
# In dev shell, always pin zsh config root to sandbox ~/.config/zsh.
if [[ -n "${DOTFILES_DEV_SHELL:-}" ]]; then
  export ZSH_CONFIG_HOME="$XDG_CONFIG_HOME/zsh"
else
  # Outside dev shell, honor externally provided override if present.
  export ZSH_CONFIG_HOME="${ZSH_CONFIG_HOME:-$XDG_CONFIG_HOME/zsh}"
fi

# Keep a reload command available even if deeper modules fail to load.
# Clear any existing alias so the function definition never collides.
(( $+aliases[reload] )) && unalias reload
reload() {
  # Exported by scripts/dev-shell; empty outside sandbox usage.
  local dev_root="${DOTFILES_DEV_ROOT:-}"

  # Fallback: infer repo root from a symlinked ~/.zshrc target.
  if [[ -z "$dev_root" && -L "$HOME/.zshrc" ]]; then
    dev_root="$(cd -P -- "$(dirname -- "$HOME/.zshrc")/.." && pwd)"
  fi

  # In dev shell, restart through wrapper to re-project symlinks and env.
  if [[ -n "${DOTFILES_DEV_SHELL:-}" && -x "$dev_root/scripts/dev-shell" ]]; then
    exec "$dev_root/scripts/dev-shell"
  fi

  # Outside dev shell, standard lightweight config reload.
  source ~/.zshrc
}

# Load the modular zsh config if it exists.
if [[ -r "$ZSH_CONFIG_HOME/zshrc" ]]; then
  if ! source "$ZSH_CONFIG_HOME/zshrc"; then
    echo "zsh: failed to load main config: $ZSH_CONFIG_HOME/zshrc" >&2
  fi
fi
