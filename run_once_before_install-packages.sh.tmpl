{{- $codespaces := env "CODESPACES" | not | not -}}
{{- if (and (eq .chezmoi.os "linux") $codespaces) -}}
#!/bin/bash
# Install packages in GitHub Codespaces
set -e

echo "==> Installing Codespaces packages..."

# Update apt cache
sudo apt-get update -qq

# Install neovim: Skipped due to Codespaces glibc compatibility issues
# Uncomment and adjust version if needed in the future

# Install antidote plugin manager
if [[ ! -d "$HOME/.antidote" ]]; then
  echo "Installing antidote..."
  git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
fi

# Install core utilities
echo "Installing apt packages..."
sudo apt-get install -y -qq \
  ripgrep \
  fd-find

# Install/upgrade fzf (apt version in Codespaces images is often too old for fzf-tab)
if ! command -v fzf >/dev/null 2>&1 || ! fzf --version | awk 'NR==1 { split($1,v,"."); ok=((v[1]+0)>0 || ((v[1]+0)==0 && (v[2]+0)>=48)); exit(ok?0:1) }'; then
  echo "Installing fzf..."
  FZF_VERSION=$(curl -fsSL https://api.github.com/repos/junegunn/fzf/releases/latest | grep '"tag_name"' | cut -d'"' -f4 | sed 's/^v//')
  FZF_URL="https://github.com/junegunn/fzf/releases/download/v${FZF_VERSION}/fzf-${FZF_VERSION}-linux_amd64.tar.gz"
  mkdir -p "$HOME/.local/bin"
  wget -q "$FZF_URL" -O /tmp/fzf.tar.gz
  tar -xzf /tmp/fzf.tar.gz -C /tmp
  install -m 0755 /tmp/fzf "$HOME/.local/bin/fzf"
  rm -f /tmp/fzf.tar.gz /tmp/fzf
fi

# Install starship prompt
if ! command -v starship >/dev/null 2>&1; then
  echo "Installing starship..."
  mkdir -p "$HOME/.local/bin"
  curl -fsSL https://starship.rs/install.sh | sh -s -- -y -b "$HOME/.local/bin"
fi

# Install tree-sitter CLI (required by Neovim treesitter tooling).
if ! command -v tree-sitter >/dev/null 2>&1; then
  echo "Installing tree-sitter-cli..."
  [[ -r "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"
  cargo install --locked tree-sitter-cli
fi

# Install zellij (terminal multiplexer)
if ! command -v zellij >/dev/null 2>&1; then
  echo "Installing zellij..."
  ZELLIJ_VERSION=$(curl -s https://api.github.com/repos/zellij-org/zellij/releases/latest | grep '"tag_name"' | cut -d'"' -f4 | sed 's/^v//')
  ZELLIJ_URL="https://github.com/zellij-org/zellij/releases/download/v${ZELLIJ_VERSION}/zellij-x86_64-unknown-linux-musl.tar.gz"
  wget -q "$ZELLIJ_URL" -O /tmp/zellij.tar.gz
  sudo tar -xzf /tmp/zellij.tar.gz -C /usr/local/bin
  sudo chmod +x /usr/local/bin/zellij
  rm /tmp/zellij.tar.gz
fi

# Install eza (modern ls)
if ! command -v eza >/dev/null 2>&1; then
  echo "Installing eza..."
  sudo mkdir -p /etc/apt/keyrings
  wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | \
    sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg 2>/dev/null
  echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | \
    sudo tee /etc/apt/sources.list.d/gierens.list >/dev/null
  sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
  sudo apt-get update -qq
  sudo apt-get install -y -qq eza
fi

# Install bat (better cat)
if ! command -v bat >/dev/null 2>&1; then
  echo "Installing bat..."
  sudo apt-get install -y -qq bat
  mkdir -p "$HOME/.local/bin"
  ln -sf /usr/bin/batcat "$HOME/.local/bin/bat"
fi

# Install git-delta (better git diff)
if ! command -v delta >/dev/null 2>&1; then
  echo "Installing git-delta..."
  DELTA_VERSION="0.18.2"
  DELTA_URL="https://github.com/dandavison/delta/releases/download/${DELTA_VERSION}/git-delta_${DELTA_VERSION}_amd64.deb"
  wget -q "$DELTA_URL" -O /tmp/git-delta.deb
  sudo dpkg -i /tmp/git-delta.deb
  rm /tmp/git-delta.deb
fi

echo "==> Codespaces setup complete!"
echo "Run 'reload' to apply zsh configuration"
{{- end -}}
